{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    ".expo/types/**/*.ts", 
    "expo-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.json",
    "**/.*/**/*.ts",
    "**/.*/**/*.tsx",
    "**/.*/**/*.tsx",
    "**/*.js",
    "**/*.d.ts",
    "eslint.config.mjs"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/Pods",
    "ios",
    "android",
  ]
}
